/phys/addPhysics emlivermore
/cuts/setLowEdge 250 eV
/process/em/fluo true
/process/em/auger true
/process/em/pixe true
/phys/setGCut  1 nm
/phys/setECut  1 nm
/run/setCut  0.01 mm


/GsimTrackingAction/setBriefTrackStore true

/GsimDetector/world/setParameters 2*m 2*m 2*m
/GsimDetector/world/setOuterVisibility 0

/GsimDetectorFactory/GsimBox/buildAndRegister box /world 0 0 ({tBoxB}-{tBoxS})*0.5*mm 0 0 0 
/GsimDetector/world/box/setParameters 30*cm+{tBoxS}*2*mm 30*cm+{tBoxS}*2*mm 30*cm+({tBoxB}+{tBoxS})*mm
/GsimDetector/world/box/setOuterMaterial G4_Pb
/GsimDetector/world/box/setSensitiveDetectorWithName box 0

/GsimDetectorFactory/GsimBox/buildAndRegister air /world/box 0 0 -({tBoxB}-{tBoxS})*0.5*mm 0 0 0
/GsimDetector/world/box/air/setParameters 30*cm 30*cm 30*cm
/GsimDetector/world/box/air/setOuterMaterial G4_AIR


/GsimDetectorFactory/GsimBox/buildAndRegister plx0 /world 15*cm+{tBoxS}*mm+1*mm 0 0 0 0 0 
/GsimDetector/world/plx0/setParameters 1*mm 30*cm 30*cm
/GsimDetector/world/plx0/setOuterMaterial G4_AIR
/GsimDetector/world/plx0/setSensitiveDetectorWithName pl 0

/GsimDetectorFactory/GsimBox/buildAndRegister plx1 /world -(15*cm+{tBoxS}*mm+1*mm) 0 0 0 0 0 
/GsimDetector/world/plx1/setParameters 1*mm 30*cm 30*cm
/GsimDetector/world/plx1/setOuterMaterial G4_AIR
/GsimDetector/world/plx1/setSensitiveDetectorWithName pl 1

/GsimDetectorFactory/GsimBox/buildAndRegister ply0 /world 0 15*cm+{tBoxS}*mm+1*mm 0 0 0 0 
/GsimDetector/world/ply0/setParameters 30*cm 1*mm 30*cm
/GsimDetector/world/ply0/setOuterMaterial G4_AIR
/GsimDetector/world/ply0/setSensitiveDetectorWithName pl 2

/GsimDetectorFactory/GsimBox/buildAndRegister ply1 /world 0 -(15*cm+{tBoxS}*mm+1*mm) 0 0 0 0 
/GsimDetector/world/ply1/setParameters 30*cm 1*mm 30*cm
/GsimDetector/world/ply1/setOuterMaterial G4_AIR
/GsimDetector/world/ply1/setSensitiveDetectorWithName pl 3


/GsimDetectorFactory/GsimBox/buildAndRegister plz0 /world 0 0 15*cm+{tBoxB}*mm+1*mm 0 0 0 
/GsimDetector/world/plz0/setParameters 40*cm 40*cm 1*mm 
/GsimDetector/world/plz0/setOuterMaterial G4_AIR
/GsimDetector/world/plz0/setSensitiveDetectorWithName pl 4


/GsimDetectorFactory/GsimBox/buildAndRegister plz1 /world 0 0 -(15*cm+{tBoxS}*mm+1*mm) 0 0 0 
/GsimDetector/world/plz1/setParameters 40*cm 40*cm 1*mm 
/GsimDetector/world/plz1/setOuterMaterial G4_AIR
/GsimDetector/world/plz1/setSensitiveDetectorWithName pl 5


/GsimDetectorFactory/GsimBox/buildAndRegister inz1 /world/box/air 0 0 -15*cm+1*0.5*mm 0 0 0 
